{
  "name": "@paid-tw/einvoice",
  "version": "0.3.2",
  "description": "Provider-agnostic core for Taiwan e-invoice: unified types, InvoiceProvider interface, validation schemas, and a MockProvider.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paid-tw/einvoice.git",
    "directory": "packages/einvoice"
  },
  "homepage": "https://github.com/paid-tw/einvoice/tree/main/packages/einvoice#readme",
  "bugs": "https://github.com/paid-tw/einvoice/issues",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "einvoice",
    "e-invoice",
    "taiwan",
    "電子發票",
    "invoice",
    "fapiao"
  ],
  "publishConfig": {
    "access": "public"
  }
}
