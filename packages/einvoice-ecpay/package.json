{
  "name": "@paid-tw/einvoice-ecpay",
  "version": "0.4.1",
  "description": "ECPay 綠界 (ecpay.com.tw) adapter for @paid-tw/einvoice — implements InvoiceProvider over the ECPay B2C e-invoice 2.0 API.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paid-tw/einvoice.git",
    "directory": "packages/einvoice-ecpay"
  },
  "homepage": "https://github.com/paid-tw/einvoice/tree/main/packages/einvoice-ecpay#readme",
  "bugs": "https://github.com/paid-tw/einvoice/issues",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paid-tw/einvoice": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "einvoice",
    "電子發票",
    "ecpay",
    "綠界",
    "taiwan"
  ],
  "publishConfig": {
    "access": "public"
  }
}
