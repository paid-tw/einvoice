{
  "name": "@paid-tw/einvoice-ezpay",
  "version": "0.3.1",
  "description": "ezPay (ezpay.com.tw) adapter for @paid-tw/einvoice — implements InvoiceProvider over the ezPay e-invoice API.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paid-tw/einvoice.git",
    "directory": "packages/einvoice-ezpay"
  },
  "homepage": "https://github.com/paid-tw/einvoice/tree/main/packages/einvoice-ezpay#readme",
  "bugs": "https://github.com/paid-tw/einvoice/issues",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paid-tw/einvoice": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "einvoice",
    "電子發票",
    "ezpay",
    "藍新",
    "taiwan"
  ],
  "publishConfig": {
    "access": "public"
  }
}
