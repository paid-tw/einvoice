# Environment variables for the LIVE test suites only.
#
# The default `pnpm test` runs entirely offline (MSW mocks) and needs none of
# these. Each provider's `live.test.ts` is gated behind its `*_LIVE=1` flag and
# is skipped unless that flag and the provider's credentials are present.
#
# Copy to `.env` (git-ignored) and fill in your sandbox credentials. Run a single
# provider's live suite, e.g.:
#   pnpm exec vitest run packages/einvoice-amego/src/__tests__/live.test.ts

# ── Amego (amego.tw) ──────────────────────────────────────────────────────────
AMEGO_LIVE=1
AMEGO_SELLER=12345678          # 賣方統一編號 (seller tax ID)
AMEGO_APP_KEY=                 # Amego app key (server-side only)
# AMEGO_LIVE_MUTATE=1          # optional — also run the mutating (issue/void) tests

# ── ECPay 綠界 (ecpay.com.tw) ─────────────────────────────────────────────────
# Optional: defaults to ECPay's public sandbox (merchant 2000132) when unset.
ECPAY_LIVE=1
# ECPAY_MERCHANT_ID=2000132
# ECPAY_HASH_KEY=              # 16 chars (AES-128)
# ECPAY_HASH_IV=               # 16 chars

# ── ezPay 藍新 (ezpay.com.tw) ─────────────────────────────────────────────────
EZPAY_LIVE=1
EZPAY_MERCHANT_ID=
EZPAY_HASH_KEY=                # 32 chars (AES-256)
EZPAY_HASH_IV=                 # 16 chars

# ── ezPay cross-border 境外電商 ───────────────────────────────────────────────
# Reuses the EZPAY_* credentials above, but the merchant must be a 境外電商 type.
EZPAY_CB_LIVE=1

# ── ezReceipt 易發票 (COIMOTION) ──────────────────────────────────────────────
# Use a DEDICATED API account — COIMOTION allows one active token per account, so
# an API login logs out a web session on the same account.
EZRECEIPT_LIVE=1
EZRECEIPT_APPCODE=
EZRECEIPT_APPKEY=
EZRECEIPT_ACCNAME=
EZRECEIPT_PASSWORD=
