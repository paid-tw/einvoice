{
  "name": "einvoice-tw",
  "version": "0.0.0",
  "private": true,
  "description": "Unified e-invoice SDK for Taiwan — one interface, multiple providers (Amego, ECPay, ezPay, MOF).",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "dev": "pnpm -r --parallel --filter './packages/*' dev",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -b --noEmit || true",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo && rm -rf node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^2.1.0",
    "msw": "^2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
